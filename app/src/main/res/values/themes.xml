<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="Theme.AxisFasting" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- Splash Screen theme. -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <item name="windowSplashScreenAnimatedIcon">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.AxisFasting</item>
        <item name="android:windowIsTranslucent">true</item>
    </style>
</resources>
